{
  "expo": {
    "name": "Bayer Operacional",
    "slug": "bayer-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/icon.png",
    "scheme": "bayeroperacional",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": "true",
    "ios": {
      "supportsTablet": "true"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo/android-chrome-512x512.png",
        "backgroundImage": "./assets/logo/android-chrome-512x512.png",
        "monochromeImage": "./assets/logo/android-chrome-512x512.png"
      },
      "edgeToEdgeEnabled": "true",
      "predictiveBackGestureEnabled": "false",
      "package": "com.rwbe.bayerapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/favicon.ico"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "22c92b74-aef9-462f-8b4f-87a3168d1d56"
      }
    }
  }
}
